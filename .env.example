# =============================================================================
# Application Configuration
# =============================================================================

# --- Application Core Settings ---

APP_NAME=Geni
APP_ENV=local
DEBUG=true
API_PREFIX=/api

# =============================================================================
# Database Configuration
# =============================================================================

# --- PostgreSQL Connection Settings ---

POSTGRES_USER=geni
POSTGRES_PASSWORD=geni_password
POSTGRES_DB=geni
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
DATABASE_URL=postgresql+asyncpg://geni:geni_password@localhost:5432/geni
